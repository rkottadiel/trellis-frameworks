---
const { title = 'Trellis Frameworks' } = Astro.props;
---

<html lang="en">
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Lora:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/styles/tokens.css" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Frameworks for PMs navigating the AI shift." />
    <title>{title}</title>
  </head>
  <body class="bg-brand-bg text-brand-text font-sans antialiased">

    <nav class="border-b border-[#E7E5E4] px-6 py-4">
      <div class="max-w-4xl mx-auto flex items-center justify-between">
        <a href="/" class="text-sm font-semibold tracking-tight text-[#1C1917]">
          Trellis Frameworks
        </a>
        <div class="flex gap-6 text-sm text-[#78716C]">
          <a href="/writing" class="hover:text-[#1C1917] transition-colors">Writing</a>
          <a href="/tools" class="hover:text-[#1C1917] transition-colors">Tools</a>
          <a href="/frameworks" class="hover:text-[#1C1917] transition-colors">Frameworks</a>
          <a href="/about" class="hover:text-[#1C1917] transition-colors">About</a>
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="border-t border-[#E7E5E4] px-6 py-8 mt-24">
      <div class="max-w-4xl mx-auto flex items-center justify-between text-sm text-[#78716C]">
        <span>© 2025 Trellis Frameworks</span>
        <span>Built for PMs navigating the AI shift.</span>
      </div>
    </footer>

  </body>
</html>